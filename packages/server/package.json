{
  "name": "@local-firestore/server",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "bin": {
    "local-firestore": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@local-firestore/shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.7.0",
    "nanoid": "^5.1.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "firebase-admin": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
